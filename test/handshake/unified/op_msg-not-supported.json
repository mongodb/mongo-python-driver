{
  "description": "op_msg not supported",
  "schemaVersion": "1.3",
  "runOnRequirements": [
    {
      "minServerVersion": "4.4"
    }
  ],
  "createEntities": [
    {
      "client": {
        "id": "setupClient",
        "useMultipleMongoses": false
      }
    },
    {
      "client": {
        "id": "client",
        "useMultipleMongoses": false,
        "uriOptions": {
          "appName": "op-msg-handshake-test",
          "serverSelectionTimeoutMS": 500
        }
      }
    },
    {
      "database": {
        "id": "database",
        "client": "client",
        "databaseName": "test"
      }
    }
  ],
  "tests": [
    {
      "description": "server closing connection during initial hello produces an error",
      "operations": [
        {
          "name": "failPoint",
          "object": "testRunner",
          "arguments": {
            "client": "setupClient",
            "failPoint": {
              "configureFailPoint": "failCommand",
              "mode": "alwaysOn",
              "data": {
                "failCommands": [
                  "hello",
                  "isMaster"
                ],
                "appName": "op-msg-handshake-test",
                "closeConnection": true
              }
            }
          }
        },
        {
          "name": "runCommand",
          "object": "database",
          "arguments": {
            "commandName": "ping",
            "command": {
              "ping": 1
            }
          },
          "expectError": {
            "errorContains": "connection closed",
            "isClientError": false
          }
        }
      ]
    }
  ]
}
